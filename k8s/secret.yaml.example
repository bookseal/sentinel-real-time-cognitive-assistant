# -----------------------------------------------------------------------------
# Kubernetes Secret Template for Sentinel
#
# Purpose: Injects the OPENAI_API_KEY into Sentinel pods as an environment
#          variable. The actual secret.yaml is .gitignored and MUST NOT be
#          committed to version control.
#
# Usage:
#   1. Copy this file:  cp secret.yaml.example secret.yaml
#   2. Generate your base64-encoded key:
#        echo -n "sk-your-real-key-here" | base64
#   3. Replace the placeholder below with the base64 output
#   4. Apply:  kubectl apply -f k8s/secret.yaml
# -----------------------------------------------------------------------------

apiVersion: v1
kind: Secret
metadata:
  name: sentinel-secret
  namespace: default
type: Opaque
data:
  # Base64-encoded OpenAI API key
  # Generate with: echo -n "sk-your-key" | base64
  OPENAI_API_KEY: REPLACE_WITH_BASE64_ENCODED_KEY
